{
  "swagger": "2.0",
  "info": {
    "title": "Transaction Notification API - Sandbox",
    "x-ibm-name": "transaction-notification-api",
    "version": "1.0.0",
    "description": "Allows you to get a notification anytime a transaction is made on your account",
    "contact": {
      "email": "kilele@stanbic.com"
    }
  },
  "x-ibm-configuration": {
    "cors": {
      "enabled": false
    },
    "type": "rest",
    "phase": "realized",
    "enforced": true,
    "testable": true,
    "servers": [
      {
        "url": "https://sandbox.connect.stanbicbank.co.ke/api/sandbox/transaction-notification-api",
        "description": "",
        "type": [
          "production",
          "development"
        ]
      }
    ]
  },
  "basePath": "/api/sandbox/transaction-notification-api",
  "paths": {
    "/": {
      "post": {
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Register the callback url for the client Information request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/TransactionNotificationRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully processed",
            "schema": {
              "$ref": "#/definitions/TransactionNotificationResponse"
            }
          }
        },
        "consumes": [],
        "produces": []
      }
    }
  },
  "definitions": {
    "TransactionNotificationResponse": {
      "type": "object",
      "properties": {
        "Result": {
          "type": "object",
          "properties": {
            "ResultCode": {
              "type": "string",
              "example": 0
            },
            "ResultDesc": {
              "type": "string",
              "example": "Accepted"
            }
          }
        }
      }
    },
    "TransactionNotificationRequest": {
      "type": "object",
      "properties": {
        "Letter": {
          "type": "object",
          "required": [
            "ApiKey"
          ],
          "properties": {
            "AlertType": {
              "type": "string",
              "example": "Letter"
            },
            "AlertName": {
              "type": "string",
              "example": "TRANSACTION"
            },
            "SendTo": {
              "type": "string",
              "example": "example@stanbic.com"
            },
            "AccountNo": {
              "type": "string",
              "example": 100004790485
            },
            "CustomerNo": {
              "type": "string",
              "example": 959043
            },
            "Subject": {
              "type": "string",
              "example": "e-Alert on Account  XXXX REVENUE COLL ACC - 01XXXXXXX0485"
            },
            "CustomerName": {
              "type": "string",
              "example": "XXX CO.LTD."
            },
            "Date": {
              "type": "string",
              "example": "10/03/2020 at 09:11AM"
            },
            "ValueDate": {
              "type": "string",
              "example": "10/03/2020"
            },
            "ActionType": {
              "type": "string",
              "example": "DEBIT"
            },
            "TxnDescr": {
              "type": "string",
              "example": "Account Transfer"
            },
            "TxnAmount": {
              "type": "string",
              "example": "KES 1,234.00"
            },
            "OurTxnReference": {
              "type": "string",
              "example": "FT20070YCTF8999\\BNK"
            },
            "ThirdPartyRef": {
              "type": "string",
              "example": "MXProoWECCC"
            },
            "TransactionOriginationBranch": {
              "type": "string",
              "example": "Head Office - UAT"
            },
            "Narrative": {
              "type": "string",
              "example": "Account Transfer\\5677888888\\nTEST"
            },
            "CurrentBalance": {
              "type": "string",
              "example": "KES 344,018,454.07"
            },
            "AvailableBalance": {
              "type": "string",
              "example": "KES 344,018,454.07"
            },
            "ClearedBalance": {
              "type": "string",
              "example": "KES 344,018,454.07"
            },
            "AccountOfficer": {
              "type": "string",
              "example": 2609
            },
            "ApiKey": {
              "type": "string",
              "example": "XDETTTSSREFT",
              "minLength": 1
            },
            "ClientFormat": {
              "type": "string",
              "example": "XML/JSON"
            },
            "MSISDN": {
              "type": "string"
            },
            "PAYER.REF": {
              "type": "string",
              "example": 40000
            },
            "CallbackUrl": {
              "type": "string",
              "example": "https://example.com"
            }
          }
        }
      }
    },
    "OutboundTransactionNotificationRequest": {
      "description": "",
      "type": "object",
      "properties": {
        "TransactionType": {
          "type": "string"
        },
        "TransID": {
          "type": "string"
        },
        "TransTime": {
          "type": "string"
        },
        "TransAmount": {
          "type": "string"
        },
        "BusinessShortCode": {
          "type": "string"
        },
        "BusinessAccountNo": {
          "type": "string"
        },
        "BillRefNumber": {
          "type": "string"
        },
        "InvoiceNumber": {
          "type": "string"
        },
        "OrgAccountBalance": {
          "type": "string"
        },
        "AvailableAccountBalance": {
          "type": "string"
        },
        "ThirdPartyTransID": {
          "type": "string"
        },
        "MSISDN": {
          "type": "string"
        },
        "PaymentDetails": {
          "type": "string"
        },
        "FirstName": {
          "type": "string"
        },
        "MiddleName": {
          "type": "string"
        },
        "LastName": {
          "type": "string"
        }
      },
      "example": "{\"TransactionType\":\"{TxnDescr}\",\"TransID\":\"{OurTxnReference}\",\"TransTime\":\"{Date}\",\"TransAmount\":\"{TxnAmount}\",\"BusinessShortCode\":\"{AccountNo}\",\"BusinessAccountNo\":\"{AccountNo}\",\"BillRefNumber\":\"{PAYER.REF}\",\"InvoiceNumber\":\"{PAYER.REF}\",\"OrgAccountBalance\":\"{AvailableBalance}\",\"AvailableAccountBalance\":\"{AvailableBalance}\",\"ThirdPartyTransID\":\"{ThirdPartyRef}\",\"MSISDN\":\"{MSISDN}\",\"PaymentDetails\":\"{Narrative}\",\"FirstName\":\"{Narrative}\",\"MiddleName\":\"{Narrative}\",\"LastName\":\"\"}"
    },
    "BackendResponse": {
      "description": "",
      "type": "object",
      "properties": {
        "ResultCode": {
          "type": "number"
        },
        "ResultDesc": {
          "type": "string"
        }
      },
      "example": "{\"ResultCode\":0,\"ResultDesc\":\"Accepted\"}"
    }
  },
  "securityDefinitions": {
    "clientID": {
      "type": "apiKey",
      "in": "header",
      "name": "X-IBM-Client-Id"
    }
  },
  "security": [
    {
      "clientID": []
    }
  ],
  "schemes": [
    "https"
  ],
  "consumes": [
    "application/xml"
  ],
  "produces": [
    "application/xml"
  ],
  "host": "sandbox.connect.stanbicbank.co.ke"
}